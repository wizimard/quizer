generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserModel {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizes QuizModel[]
}

model QuizModel {
  id String @id @default(uuid())
  title String
  image String?
  author UserModel @relation(fields: [authorId], references: [id])
  authorId String

  questions QuizQuestionModel[]

  isOpen Boolean @default(false)

  availablePeriods QuizAvailablePeriodModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizQuestionModel {
  id String @id @default(uuid())

  quiz QuizModel @relation(fields: [quizId], references: [id])
  quizId String
  
  order Int
  description String
  config Json
}

model QuizAvailablePeriodModel {
  id BigInt @id  @default(autoincrement())

  quiz QuizModel @relation(fields: [quizId], references: [id])
  quizId String

  available_from DateTime
  available_to DateTime?
}