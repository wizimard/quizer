generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserModel {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  quizes    QuizModel[]
}

model QuizModel {
  id           String              @id @default(uuid())
  title        String
  authorId     String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  image        String?
  type         String              @default("private")
  author       UserModel           @relation(fields: [authorId], references: [id])
  questions    QuizQuestionModel[]
  quizSettings QuizSettingsModel?

  quizSessions QuizSessionModel[]
}

model QuizSettingsModel {
  id                           String                     @id @default(uuid())
  quizId                       String                     @unique
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  isShowAnswersAfterCompletion Boolean                    @default(false)
  isRequiredEmail              Boolean                    @default(false)
  isRequiredFirstName          Boolean                    @default(true)
  isRequiredLastName           Boolean                    @default(true)
  availablePeriods             QuizAvailablePeriodModel[]
  quiz                         QuizModel                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizQuestionModel {
  id          String    @id @default(uuid())
  quizId      String
  order       Int
  description String
  config      Json
  quiz        QuizModel @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAvailablePeriodModel {
  id             BigInt            @id @default(autoincrement())
  available_from DateTime
  available_to   DateTime?
  quizSettingsId String
  quizSettings   QuizSettingsModel @relation(fields: [quizSettingsId], references: [id], onDelete: Cascade)
}

model QuizSessionModel {
  id String @id @default(uuid())
  quizId String
  startedAt DateTime @default(now())
  finishedAt DateTime?
  status QuizSessionStatus @default(ACTIVE)

  quiz QuizModel @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, status])
}

enum QuizSessionStatus {
  ACTIVE @map("active")
  FINISHED @map("finished")
  EXPIRED @map("expired")
}