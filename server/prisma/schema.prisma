generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserModel {
  id          String @id @default(uuid())
  email       String @unique
  password    String

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tests       TestModel[]
}

model TestModel {
  id                String  @id @default(uuid())
  title             String
  image             String?

  author_id         String
  author            UserModel @relation(fields: [author_id], references: [id])

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  test_settings     TestSettingsModel?

  questions         TestQuestionModel[]
  test_sessions     TestSessionModel[]
  scheduler_periods TestSchedulerPeriodModel[]
  
  @@index([author_id])
}

model TestSettingsModel {
  id                            String @id @default(uuid())

  test_id                       String    @unique
  test                          TestModel @relation(fields: [test_id], references: [id], onDelete: Cascade)

  show_answers_after_completion Boolean @default(false)

  created_at                    DateTime @default(now())
  updated_at                    DateTime @updatedAt
}

model TestQuestionModel {
  id          String @id @default(uuid())

  test_id     String
  test        TestModel @relation(fields: [test_id], references: [id], onDelete: Cascade)

  description String
  sort_key    Int
  config      Json?

  answers         TestSessionAnswerModel[]

  @@index([test_id])
}

model TestSchedulerPeriodModel {
  id              BigInt @id @default(autoincrement())

  test_id         String
  test            TestModel @relation(fields: [test_id], references: [id], onDelete: Cascade)

  available_from  DateTime
  available_to    DateTime?

  @@index([test_id])
  @@index([available_from])
}

model TestSessionModel {
  id          String @id @default(uuid())

  test_id     String
  test        TestModel @relation(fields: [test_id], references: [id], onDelete: Cascade)

  started_at  DateTime  @default(now())
  finished_at DateTime?

  status      TestSessionStatus  @default(ACTIVE)
  start_by    TestSessionStartBy @default(MANUALLY)

  registered_users TestSessionRegisteredUserModel[]

  @@index([test_id])
  @@index([test_id, status])
}

enum TestSessionStatus {
  ACTIVE   @map("active")
  FINISHED @map("finished")
  EXPIRED  @map("expired")
}

enum TestSessionStartBy {
  MANUALLY  @map("manually")
  SCHEDULED @map("scheduled")
}

model TestSessionRegisteredUserModel {
  id          String @id @default(uuid())

  first_name  String
  last_name   String

  test_session_id String
  test_session    TestSessionModel @relation(fields: [test_session_id], references: [id], onDelete: Cascade)

  answers         TestSessionAnswerModel[]

  created_at      DateTime @default(now())

  @@index([test_session_id])
}

model TestSessionAnswerModel {
  id          String @id @default(uuid())

  questionId String
  question   TestQuestionModel @relation(fields: [questionId], references: [id], onDelete: Cascade)

  test_session_registered_user_id String
  test_session_registered_user    TestSessionRegisteredUserModel @relation(fields: [test_session_registered_user_id], references: [id], onDelete: Cascade)

  value String?

  skipped Boolean @default(false)

  created_at      DateTime @default(now())

  @@index([test_session_registered_user_id])
  @@index([questionId])
  
  @@unique([questionId, test_session_registered_user_id])
}