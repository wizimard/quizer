{
    "openapi": "3.0.4",
    "info": {
        "title": "Quiz API",
        "description": "API documentation generated from src/modules controllers and DTOs.",
        "version": "0.0.1"
    },
    "servers": [
        {
            "url": "http://localhost:8031/api",
            "description": "Main api server"
        }
    ],
    "tags": [
        { "name": "auth", "description": "identity-access" },
        { "name": "user", "description": "identity-access" },
        { "name": "test", "description": "test-management" },
        { "name": "question", "description": "test-management" },
        { "name": "test-execute", "description": "test-execution" }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "tags": ["auth"],
                "summary": "Login user",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/UserLoginRequestBody" },
                            "examples": {
                                "Login": {
                                    "value": {
                                        "email": "user1@mail.com",
                                        "password": "password1"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login success",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/UserAuthResponse" }
                            }
                        }
                    },
                    "422": { "description": "Validation failed" }
                }
            }
        },
        "/auth/register": {
            "post": {
                "tags": ["auth"],
                "summary": "Register user",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/UserRegisterRequestBody" }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Register success",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/UserAuthResponse" }
                            }
                        }
                    },
                    "422": { "description": "Validation failed" },
                    "500": { "description": "Register failed" }
                }
            }
        },
        "/auth/refresh": {
            "post": {
                "tags": ["auth"],
                "summary": "Refresh token",
                "description": "Refresh JWT access token using the refreshToken HTTP-only cookie set by login or register.",
                "responses": {
                    "200": {
                        "description": "JWT token refreshed",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/RefreshTokenResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "tags": ["auth"],
                "summary": "Logout",
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Logout success" },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/user/me": {
            "get": {
                "tags": ["user"],
                "summary": "Get authorized user",
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/UserResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/test": {
            "get": {
                "tags": ["test"],
                "summary": "Get author's tests",
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": { "$ref": "#/components/schemas/TestResponseBase" }
                                }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" }
                }
            },
            "post": {
                "tags": ["test"],
                "summary": "Create test",
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/TestCreateRequestBody" }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Test created",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TestResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "422": { "description": "Validation failed" }
                }
            }
        },
        "/test/{testId}": {
            "get": {
                "tags": ["test"],
                "summary": "Get test by id",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Test found",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TestResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" }
                }
            },
            "patch": {
                "tags": ["test"],
                "summary": "Update test",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/TestUpdateRequestBody" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Test updated",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TestResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" },
                    "422": { "description": "Validation failed" }
                }
            },
            "delete": {
                "tags": ["test"],
                "summary": "Delete test",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "204": { "description": "No content" },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" }
                }
            }
        },
        "/test/{testId}/settings": {
            "patch": {
                "tags": ["test"],
                "summary": "Update test settings",
                "description": "Update test title and boolean settings. Availability periods are managed via PATCH /test/{testId}/scheduler/periods.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/TestSettingsUpdateRequestBody" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Test settings updated",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TestResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "422": { "description": "Validation failed" }
                }
            }
        },
        "/test/{testId}/scheduler/periods": {
            "patch": {
                "tags": ["test"],
                "summary": "Update test scheduler periods",
                "description": "Add, update or remove test availability periods.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/TestSchedulerPeriodsEditRequestBody" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Scheduler periods updated",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TestSchedulerResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "422": { "description": "Validation failed" }
                }
            }
        },
        "/test/{testId}/start": {
            "post": {
                "tags": ["test"],
                "summary": "Start test",
                "description": "Open test for execution.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/TestStartRequestBody" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Test started",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/MessageResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" }
                }
            }
        },
        "/test/{testId}/finish": {
            "post": {
                "tags": ["test"],
                "summary": "Finish test",
                "description": "Close test for execution.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Test finished",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/MessageResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" }
                }
            }
        },
        "/question/{testId}/questions": {
            "post": {
                "tags": ["question"],
                "summary": "Create question",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/QuestionCreateRequestBody" }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Question created",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/QuestionResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" },
                    "422": { "description": "Validation failed" }
                }
            }
        },
        "/question/{testId}/questions/{questionId}": {
            "patch": {
                "tags": ["question"],
                "summary": "Update question",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "questionId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/QuestionUpdateRequestBody" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Question updated",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/QuestionResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" },
                    "422": { "description": "Validation failed" }
                }
            },
            "delete": {
                "tags": ["question"],
                "summary": "Delete question",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "questionId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "204": { "description": "No content" },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" }
                }
            }
        },
        "/question/{testId}/questions/{questionId}/order": {
            "patch": {
                "tags": ["question"],
                "summary": "Change question order",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "questionId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/QuestionChangeOrderRequestBody" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Question order changed",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TestResponse" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "Not found" },
                    "422": { "description": "Validation failed" }
                }
            }
        },
        "/test-execute/{testId}": {
            "get": {
                "tags": ["test-execute"],
                "summary": "Get test for execution",
                "description": "Public test metadata for execution (no authentication required).",
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Test found",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TestExecuteResponse" }
                            }
                        }
                    },
                    "404": { "description": "Test not found" }
                }
            }
        },
        "/test-execute/{testId}/{questionId}": {
            "get": {
                "tags": ["test-execute"],
                "summary": "Get question for execution",
                "description": "Get a test question without the correct answer (no authentication required).",
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "questionId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Question found",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/QuestionExecuteResponse" }
                            }
                        }
                    },
                    "404": { "description": "Test or question not found" }
                }
            },
            "post": {
                "tags": ["test-execute"],
                "summary": "Submit answer",
                "description": "Evaluate a submitted answer for a test question (no authentication required).",
                "parameters": [
                    {
                        "name": "testId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "questionId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/QuestionAnswerSubmitRequestBody" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Answer evaluated",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/AnswerEvaluationResponse" }
                            }
                        }
                    },
                    "404": { "description": "Test or question not found" }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "BearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "UserLoginRequestBody": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                    "email": { "type": "string", "format": "email" },
                    "password": { "type": "string", "minLength": 8, "maxLength": 255 }
                }
            },
            "UserRegisterRequestBody": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                    "email": { "type": "string", "format": "email" },
                    "password": { "type": "string", "minLength": 8, "maxLength": 255 }
                }
            },
            "UserAuthResponse": {
                "type": "object",
                "required": ["accessToken", "user"],
                "properties": {
                    "accessToken": { "type": "string" },
                    "user": {
                        "type": "object",
                        "required": ["id","email"],
                        "properties": {
                            "id": { "type": "string" },
                            "email": { "type": "string", "format": "email" }
                        }
                    }
                }
            },
            "RefreshTokenResponse": {
                "type": "object",
                "required": ["accessToken"],
                "properties": {
                    "accessToken": { "type": "string" }
                }
            },
            "UserResponse": {
                "type": "object",
                "required": ["id", "email"],
                "properties": {
                    "id": { "type": "string" },
                    "email": { "type": "string", "format": "email" }
                }
            },
            "MessageResponse": {
                "type": "object",
                "required": ["message"],
                "properties": {
                    "message": { "type": "string" }
                }
            },
            "QuestionConfigInput": {
                "type": "object",
                "required": ["answer", "ignore_case", "type"],
                "properties": {
                    "type": { "type": "string", "enum": ["input"] },
                    "answer": { "type": "string" },
                    "ignore_case": { "type": "boolean" }
                }
            },
            "QuestionConfigOption": {
                "type": "object",
                "required": ["id", "value"],
                "properties": {
                    "id": { "type": "string" },
                    "value": { "type": "string" }
                }
            },
            "QuestionConfigOptionArray": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/QuestionConfigOption" }
            },
            "QuestionConfigSingleChoise": {
                "type": "object",
                "required": ["answer", "options", "type"],
                "properties": {
                    "type": { "type": "string", "enum": ["single_choise"] },
                    "answer": { "type": "string" },
                    "options": { "$ref": "#/components/schemas/QuestionConfigOptionArray" }
                }
            },
            "QuestionConfigMultipleChoise": {
                "type": "object",
                "required": ["answer", "options", "type"],
                "properties": {
                    "type": { "type": "string", "enum": ["multiple_choise"] },
                    "answer": {
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "options": { "$ref": "#/components/schemas/QuestionConfigOptionArray" }
                }
            },
            "QuestionConfigOrderAnswerOption": {
                "type": "object",
                "required": ["optionId", "order"],
                "properties": {
                    "optionId": { "type": "string" },
                    "order": { "type": "number" }
                }
            },
            "QuestionConfigOrder": {
                "type": "object",
                "required": ["answer", "options", "type"],
                "properties": {
                    "type": { "type": "string", "enum": ["order"] },
                    "answer": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/QuestionConfigOrderAnswerOption" }
                    },
                    "options": { "$ref": "#/components/schemas/QuestionConfigOptionArray" }
                }
            },
            "QuestionRequestConfig": {
                "oneOf": [
                    { "$ref": "#/components/schemas/QuestionConfigInput" },
                    { "$ref": "#/components/schemas/QuestionConfigSingleChoise" },
                    { "$ref": "#/components/schemas/QuestionConfigMultipleChoise" },
                    { "$ref": "#/components/schemas/QuestionConfigOrder" }
                ],
                "discriminator": { "propertyName": "type" }
            },
            "QuestionCreateRequestBody": {
                "type": "object",
                "required": ["description", "config"],
                "properties": {
                    "description": { "type": "string" },
                    "config": { "$ref": "#/components/schemas/QuestionRequestConfig" }
                }
            },
            "QuestionUpdateRequestBody": {
                "type": "object",
                "required": ["description", "config"],
                "properties": {
                    "description": { "type": "string" },
                    "config": { "$ref": "#/components/schemas/QuestionRequestConfig" }
                }
            },
            "QuestionChangeOrderRequestBody": {
                "type": "object",
                "properties": {
                    "previousQuestionId": {
                        "type": "string",
                        "nullable": true,
                        "description": "ID of the question that should appear immediately before the moved question"
                    },
                    "nextQuestionId": {
                        "type": "string",
                        "nullable": true,
                        "description": "ID of the question that should appear immediately after the moved question"
                    }
                }
            },
            "QuestionResponse": {
                "type": "object",
                "required": ["id", "testId", "sortKey", "description", "config"],
                "properties": {
                    "id": { "type": "string" },
                    "testId": { "type": "string" },
                    "sortKey": { "type": "number" },
                    "description": { "type": "string" },
                    "config": { "$ref": "#/components/schemas/QuestionRequestConfig" }
                }
            },
            "TestSettings": {
                "type": "object",
                "required": [
                    "isRequiredEmail",
                    "isRequiredFirstName",
                    "isRequiredLastName",
                    "isShowAnswersAfterCompletion"
                ],
                "properties": {
                    "isRequiredEmail": { "type": "boolean" },
                    "isRequiredFirstName": { "type": "boolean" },
                    "isRequiredLastName": { "type": "boolean" },
                    "isShowAnswersAfterCompletion": { "type": "boolean" }
                }
            },
            "TestResponseBase": {
                "type": "object",
                "required": ["id", "authorId", "status", "title", "updatedAt", "createdAt"],
                "properties": {
                    "id": { "type": "string" },
                    "authorId": { "type": "string" },
                    "status": {
                        "type": "string",
                        "enum": ["open", "open_by_scheduler", "closed"]
                    },
                    "title": { "type": "string" },
                    "updatedAt": { "type": "string", "format": "date-time" },
                    "createdAt": { "type": "string", "format": "date-time" }
                }
            },
            "TestResponse": {
                "type": "object",
                "required": ["id", "authorId", "status", "title", "questions", "settings", "updatedAt", "createdAt"],
                "properties": {
                    "id": { "type": "string" },
                    "authorId": { "type": "string" },
                    "status": {
                        "type": "string",
                        "enum": ["open", "open_by_scheduler", "closed"]
                    },
                    "title": { "type": "string" },
                    "questions": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/QuestionResponse" }
                    },
                    "settings": { "$ref": "#/components/schemas/TestSettings" },
                    "updatedAt": { "type": "string", "format": "date-time" },
                    "createdAt": { "type": "string", "format": "date-time" }
                }
            },
            "TestCreateRequestBody": {
                "type": "object",
                "required": ["title"],
                "properties": {
                    "title": { "type": "string" }
                }
            },
            "TestUpdateRequestBody": {
                "type": "object",
                "properties": {
                    "title": { "type": "string" }
                }
            },
            "TestSchedulerPeriodDto": {
                "type": "object",
                "required": ["id", "available_from"],
                "properties": {
                    "id": { "type": "number" },
                    "available_from": { "type": "string", "format": "date-time" },
                    "available_to": { "type": "string", "format": "date-time" }
                }
            },
            "TestSchedulerPeriodsEditRequestBody": {
                "type": "object",
                "properties": {
                    "add": {
                        "type": "array",
                        "description": "Periods to create",
                        "items": { "$ref": "#/components/schemas/TestSchedulerPeriodDto" }
                    },
                    "update": {
                        "type": "array",
                        "description": "Existing periods to update",
                        "items": { "$ref": "#/components/schemas/TestSchedulerPeriodDto" }
                    },
                    "remove": {
                        "type": "array",
                        "description": "IDs of periods to delete",
                        "items": { "type": "number" }
                    }
                }
            },
            "TestSchedulerPeriodResponse": {
                "type": "object",
                "required": ["id", "testId", "availableFrom"],
                "properties": {
                    "id": { "type": "number" },
                    "testId": { "type": "string" },
                    "availableFrom": { "type": "string", "format": "date-time" },
                    "availableTo": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                }
            },
            "TestSchedulerResponse": {
                "type": "object",
                "required": ["periods"],
                "properties": {
                    "periods": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/TestSchedulerPeriodResponse" }
                    }
                }
            },
            "TestSettingsUpdateRequestBody": {
                "type": "object",
                "required": [
                    "title",
                    "isRequiredEmail",
                    "isRequiredFirstName",
                    "isRequiredLastName",
                    "isShowAnswersAfterCompletion"
                ],
                "properties": {
                    "title": { "type": "string", "minLength": 3 },
                    "isRequiredEmail": { "type": "boolean" },
                    "isRequiredFirstName": { "type": "boolean" },
                    "isRequiredLastName": { "type": "boolean" },
                    "isShowAnswersAfterCompletion": { "type": "boolean" }
                }
            },
            "TestStartRequestBody": {
                "type": "object",
                "properties": {
                    "duration": {
                        "type": "number",
                        "description": "Test duration in seconds"
                    }
                }
            },
            "TestExecuteResponse": {
                "type": "object",
                "required": ["id", "authorId", "title", "isOpen"],
                "properties": {
                    "id": { "type": "string" },
                    "authorId": { "type": "string" },
                    "title": { "type": "string" },
                    "isOpen": { "type": "boolean" }
                }
            },
            "QuestionExecuteConfigInput": {
                "type": "object",
                "required": ["type", "ignore_case"],
                "properties": {
                    "type": { "type": "string", "enum": ["input"] },
                    "ignore_case": { "type": "boolean" }
                }
            },
            "QuestionExecuteConfigSingleChoise": {
                "type": "object",
                "required": ["type", "options"],
                "properties": {
                    "type": { "type": "string", "enum": ["single_choise"] },
                    "options": { "$ref": "#/components/schemas/QuestionConfigOptionArray" }
                }
            },
            "QuestionExecuteConfigMultipleChoise": {
                "type": "object",
                "required": ["type", "options"],
                "properties": {
                    "type": { "type": "string", "enum": ["multiple_choise"] },
                    "options": { "$ref": "#/components/schemas/QuestionConfigOptionArray" }
                }
            },
            "QuestionExecuteConfigOrder": {
                "type": "object",
                "required": ["type", "options"],
                "properties": {
                    "type": { "type": "string", "enum": ["order"] },
                    "options": { "$ref": "#/components/schemas/QuestionConfigOptionArray" }
                }
            },
            "QuestionExecuteConfig": {
                "oneOf": [
                    { "$ref": "#/components/schemas/QuestionExecuteConfigInput" },
                    { "$ref": "#/components/schemas/QuestionExecuteConfigSingleChoise" },
                    { "$ref": "#/components/schemas/QuestionExecuteConfigMultipleChoise" },
                    { "$ref": "#/components/schemas/QuestionExecuteConfigOrder" }
                ],
                "discriminator": { "propertyName": "type" }
            },
            "QuestionExecuteResponse": {
                "type": "object",
                "required": ["id", "testId", "description", "config"],
                "properties": {
                    "id": { "type": "string" },
                    "testId": { "type": "string" },
                    "description": { "type": "string" },
                    "config": { "$ref": "#/components/schemas/QuestionExecuteConfig" }
                }
            },
            "QuestionAnswerSubmitRequestBody": {
                "type": "object",
                "required": ["answer"],
                "properties": {
                    "answer": {
                        "oneOf": [
                            {
                                "type": "string",
                                "description": "For input and single_choise question types"
                            },
                            {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "For multiple_choise question type"
                            },
                            {
                                "type": "array",
                                "items": { "$ref": "#/components/schemas/QuestionConfigOrderAnswerOption" },
                                "description": "For order question type"
                            }
                        ]
                    }
                }
            },
            "AnswerEvaluationResponse": {
                "type": "object",
                "required": ["correct"],
                "properties": {
                    "correct": { "type": "boolean" }
                }
            }
        }
    }
}
