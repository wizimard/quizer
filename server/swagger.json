{
    "openapi": "3.0.4",
    "info": {
        "title": "Quiz API",
        "description": "",
        "version": "0.0.1"
    },
    "servers": [
        {
            "url": "http://localhost:8031/api",
            "description": "Main api server"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "summary": "Login user",
                "description": "Login user",
                "requestBody": {
                    "description": "Login request body",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserLoginRequestBody"
                            },
                            "examples": {
                                "Login": {
                                    "summary": "login example",
                                    "description": "login example",
                                    "value": {
                                        "email": "user1@mail.com",
                                        "password": "password1"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login success response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserAuthResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Login validation failed"
                    }
                }
            }
        },
        "/auth/register": {
            "post": {
                "summary": "Register user",
                "description": "Register user",
                "requestBody": {
                    "description": "Register request body",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserLoginRequestBody"
                            },
                            "examples": {
                                "Login": {
                                    "summary": "register example",
                                    "description": "register example",
                                    "value": {
                                        "email": "user1@mail.com",
                                        "password": "password1"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Register success response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserAuthResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Register validation failed"
                    },
                    "500": {
                        "description": "Register failed"
                    }
                }
            }
        },
        "/auth/refresh": {
            "post": {
                "summary": "Refresh token",
                "description": "Refresh JWT token",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "JWT token refreshed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RefreshTokenResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "summary": "Logout",
                "description": "Logout",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logout success"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/user/me": {
            "get": {
                "summary": "Get authorized user",
                "description": "Get authorized user",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/GetUserResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/quiz/{id}": {
            "get": {
                "summary": "Get quiz by id",
                "description": "Get quiz by id",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Quiz found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/QuizResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Not Found"
                    },
                    "403": {
                        "description": "Don't have rights"
                    }
                }
            },
            "delete": {
                "summary": "Delete quiz by id",
                "description": "Delete quiz by id",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No content"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Not Found"
                    },
                    "403": {
                        "description": "Don't have rights"
                    }
                }
            }
        },
        "/quiz": {
            "get": {
                "summary": "Get user's quizes",
                "description": "Get user's quizes",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/QuizResponse"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            },
            "post": {
                "summary": "Create quiz",
                "description": "Create quiz",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "requestBody": {
                    "description": "Create quiz request body",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/QuizCreateRequestBody"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Quiz created success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/QuizResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "422": {
                        "description": "Validation failed"
                    },
                    "500": {
                        "description": "Creating failed"
                    }
                }
            },
            "patch": {
                "summary": "Update quiz",
                "description": "Update quiz",
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "requestBody": {
                    "description": "Updating quiz request body",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/QuizUpdateRequestBody"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Quiz updated success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/QuizResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Don't have rights"
                    },
                    "422": {
                        "description": "Validation failed"
                    },
                    "500": {
                        "description": "Creating failed"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "BearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "UserLoginRequestBody": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                    "email": {
                        "type": "string"
                    },
                    "password": {
                        "type": "string"
                    }
                }
            },
            "UserAuthResponse": {
                "type": "object",
                "required": ["accessToken", "user"],
                "properties": {
                    "accessToken": {
                        "type": "string"
                    },
                    "user": {
                        "type": "object",
                        "required": ["email"],
                        "properties": {
                            "email": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "RefreshTokenResponse": {
                "type": "object",
                "required": ["accessToken"],
                "properties": {
                    "accessToken": {
                        "type": "string"
                    }
                }
            },
            "GetUserResponse": {
                "type": "object",
                "required": ["email"],
                "properties": {
                    "email": {
                        "type": "string"
                    }
                }
            },
            "QuestionConfigInput": {
                "type": "object",
                "required": ["answer", "ignore_case", "type"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["input"]
                    },
                    "answer": {
                        "type": "string"
                    },
                    "ignore_case": {
                        "type": "boolean"
                    }
                }
            },
            "QuestionConfigOption": {
                "type": "object",
                "required": ["id", "value"],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                }
            },
            "QuestionConfigOptionArray": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/QuestionConfigOption"
                }
            },
            "QuestionConfigSingleChoise": {
                "type": "object",
                "required": ["answer", "options", "type"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["single_choise"]
                    },
                    "answer": {
                        "type": "string"
                    },
                    "options": {
                        "$ref": "#/components/schemas/QuestionConfigOptionArray"
                    }
                }
            },
            "QuestionConfigMultipleChoise": {
                "type": "object",
                "required": ["answer", "options", "type"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["multiple_choise"]
                    },
                    "answer": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "options": {
                        "$ref": "#/components/schemas/QuestionConfigOptionArray"
                    }
                }
            },
            "QuestionConfigOrderAnswerOption": {
                "type": "object",
                "required": ["optionId", "order"],
                "properties": {
                    "optionId": {
                        "type": "string"
                    },
                    "order": {
                        "type": "number"
                    }
                }
            },
            "QuestionConfigOrder": {
                "type": "object",
                "required": ["answer", "options", "type"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["order"]
                    },
                    "answer": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuestionConfigOrderAnswerOption"
                        }
                    },
                    "options": {
                        "$ref": "#/components/schemas/QuestionConfigOptionArray"
                    }
                }
            },
            "QuestionRequestConfig": {
                "oneOf": [
                        {
                            "$ref": "#/components/schemas/QuestionConfigInput"
                        },
                        {
                            "$ref": "#/components/schemas/QuestionConfigSingleChoise"
                        },
                        {
                            "$ref": "#/components/schemas/QuestionConfigMultipleChoise"
                        },
                        {
                            "$ref": "#/components/schemas/QuestionConfigOrder"
                        }
                    ],
                "discriminator": {
                    "propertyName": "type"
                }
            },
            "QuestionRequest": {
                "type": "object",
                "required": ["id", "quizId", "order", "description", "type", "config"],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "quizId": {
                        "type": "string"
                    },
                    "order": {
                        "type": "number"
                    },
                    "description": {
                        "type": "string"
                    },
                    "config": {
                        "$ref": "#/components/schemas/QuestionRequestConfig"
                    }
                }
            },
            "QuizResponse": {
                "type": "object",
                "required": ["id", "authorId", "title", "questions", "updatedAt", "createdAt"],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "authorId": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "questions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuestionRequest"
                        }
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date"
                    }
                }
            },
            "QuizCreateRequestBody": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string"
                    },
                    "questions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuestionRequest"
                        }
                    }
                }
            },
            "QuizUpdateRequestBody": {
                "type": "object",
                "required": ["id"],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "add": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuestionRequest"
                        }
                    },
                    "update": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuestionRequest"
                        }
                    },
                    "delete": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}